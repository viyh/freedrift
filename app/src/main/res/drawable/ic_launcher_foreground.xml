<?xml version="1.0" encoding="utf-8"?>
<!--
  Crescent moon + three sound-wave arcs emanating to the right.
  True crescent (two overlapping equal-radius circles) with tips at top and bottom.
  Sized down with ~10dp of padding from the safe-zone edge so nothing crowds the
  launcher mask.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Crescent: outer and cover circles both r=18, centers 8 apart.
         Traced as a single path: outer arc (LEFT side) + inner arc (the bite). -->
    <path
        android:fillColor="@color/ic_launcher_foreground"
        android:pathData="M 49,36.5 A 18,18 0 1,0 49,71.5 A 18,18 0 0,1 49,36.5 Z" />

    <!-- Three concentric arcs radiating from the moon's concave side.
         Shrunk slightly and pulled in toward the moon (radii 20/26/32, was 24/30/36). -->
    <path
        android:strokeColor="@color/ic_launcher_foreground"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 63,45.5 A 20,20 0 0,1 63,62.5
                          M 68,42   A 26,26 0 0,1 68,66
                          M 73,38.5 A 32,32 0 0,1 73,69.5" />
</vector>
